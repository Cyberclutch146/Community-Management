const mongoose = require('mongoose');

const UserSchema = new mongoose.Schema({
  name: {
    type: String,
    required: true,
  },
  email: {
    type: String,
    required: true,
    unique: true,
    lowercase: true,
    trim: true,
  },
  password: {
    type: String,
    required: true,
  },
  role: {
    type: String,
    enum: ["user", "organizer"],
    default: "user",
  },
  location: {
    lat: {
      type: Number,
    },
    lng: {
      type: Number,
    },
  },
}, {
  timestamps: true,
});

module.exports = mongoose.model('User', UserSchema);
